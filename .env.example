# k-ai environment variables — EXAMPLE FILE
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the keys you want to use.
# Keys left blank (KEY=) are silently ignored; k-ai falls back to os.environ
# and then to a zsh login-shell read (bw-env / ~/.zshrc exports).
#
# Priority:  .env (non-empty)  >  os.environ  >  zsh -l -c
#
# You only need to fill in the providers you actually use — all others are
# optional. Ollama (no_auth) needs no key at all.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (Claude) — https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Mistral AI — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=...

# Alibaba DashScope (Qwen) — https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=sk-...
