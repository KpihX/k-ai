# k-ai environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# Lines left blank (KEY=) are treated as "not set" and are ignored by k-ai.
# k-ai resolution order: this file → os.environ → zsh -l -c login shell.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# Groq
GROQ_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Alibaba DashScope (Qwen)
DASHSCOPE_API_KEY=
